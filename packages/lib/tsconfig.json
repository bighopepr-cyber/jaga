{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "module": "CommonJS",
    "types": ["node"],
    "paths": {
      "@mas/*": ["../*"]
    }
  },
  "include": ["utils/**/*"],
  "exclude": ["node_modules", "dist"]
}